# Database (change credentials for production)
POSTGRES_USER=sentry
POSTGRES_PASSWORD=sentry
POSTGRES_DB=sentry

# REQUIRED: Must match POSTGRES_USER/PASSWORD/DB above
# Docker Compose sets this automatically; only needed for standalone API
DATABASE_URL=postgresql://sentry:sentry@localhost:5432/sentry
FLASK_ENV=development
FLASK_PORT=5000

# REQUIRED: Generate with `openssl rand -hex 32`
JWT_SECRET=replace-me-with-openssl-rand-hex-32

# REQUIRED: Master key for connector credential vault (Fernet, base64, 32 bytes).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key requires decrypting all connector_credentials rows with the old
# key and re-encrypting with the new one; do not change in place.
SENTRY_ENCRYPTION_KEY=replace-me-with-fernet-generate-key

# REQUIRED: Password for the Redis broker (Celery uses Redis for task queuing).
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Rotating this requires restarting the Redis container and all Celery workers.
REDIS_PASSWORD=replace-me-with-secrets-token-hex-32

# REQUIRED (v1.5.0+): Pepper concatenated with every X-WMS-Token plaintext
# before SHA-256 hashing. Stored only in the environment (never in the DB
# or the repo). Rotating this value is an emergency-only control that
# invalidates every issued wms_tokens row at once.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SENTRY_TOKEN_PEPPER=replace-me-with-secrets-token-hex-32

# REQUIRED (v1.6.1+): HMAC key for the webhook_subscription_events Redis
# channel (#227). The cross-worker pubsub envelope is signed with this
# key; an unset or trivial value lets a Redis-side attacker forge
# eviction or secret_rotated messages. Separate from SENTRY_ENCRYPTION_KEY
# (webhook secret material) and SENTRY_TOKEN_PEPPER (inbound auth) so it
# rotates on its own schedule. Boot validation refuses the placeholder
# value and any value shorter than 32 bytes.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SENTRY_PUBSUB_HMAC_KEY=replace-me-with-secrets-token-hex-32

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080,http://localhost:8081

# Docker port bindings. Default 127.0.0.1 is correct for production deployments
# behind a reverse proxy. For LAN development where a mobile device needs to
# reach the API directly, set these to 0.0.0.0.
API_BIND_HOST=127.0.0.1
ADMIN_BIND_HOST=127.0.0.1

# ----------------------------------------------------------------------
# Reverse proxy (HTTPS termination)
# ----------------------------------------------------------------------
# TRUST_PROXY: set to true when Sentry runs behind a TLS-terminating reverse
# proxy (nginx, Caddy, Traefik, ALB, etc.) that sets X-Forwarded-Proto,
# X-Forwarded-Host, and X-Forwarded-For headers. Default false for direct
# deployments. See docs/deployment.md for the full reverse-proxy guide.
# WARNING: Only enable when actually behind a trusted proxy on a network
# the proxy controls. Trusting these headers from arbitrary clients is a
# known origin-spoofing attack vector.
TRUST_PROXY=false

# ----------------------------------------------------------------------
# Snapshot-keeper least-privilege role (v1.5.1 V-214 #153)
# ----------------------------------------------------------------------
# Optional. When unset, the snapshot-keeper container uses DATABASE_URL
# above (same role as the api). For production, run
# db/role-snapshot-keeper.sql once to create a dedicated `sentry_keeper`
# role with narrow grants (SELECT on integration_events,
# SELECT/UPDATE/DELETE on snapshot_scans, EXECUTE on
# pg_export_snapshot), then set SNAPSHOT_KEEPER_DATABASE_URL to point
# the keeper at that role. A compromise of either side no longer gives
# the attacker full DB permissions.
#
# Example:
#   SNAPSHOT_KEEPER_DATABASE_URL=postgresql://sentry_keeper:<strong-pw>@db:5432/sentry
SNAPSHOT_KEEPER_DATABASE_URL=

# ----------------------------------------------------------------------
# Webhook-dispatcher least-privilege role (v1.6.0)
# ----------------------------------------------------------------------
# Optional. When unset, the webhook-dispatcher container (added in the
# v1.6.0 dispatcher commit) uses DATABASE_URL above (same role as the
# api). For production, run db/role-dispatcher.sql once to create a
# dedicated `sentry_dispatcher` role with narrow grants (SELECT on
# integration_events, SELECT/UPDATE on webhook_subscriptions,
# INSERT/SELECT/UPDATE on webhook_deliveries + sequence USAGE, SELECT
# on webhook_secrets), then set DISPATCHER_DATABASE_URL to point the
# dispatcher at that role. Mirrors the V-214 snapshot-keeper pattern;
# a compromise of either side no longer gives the attacker full DB
# permissions.
#
# Example:
#   DISPATCHER_DATABASE_URL=postgresql://sentry_dispatcher:<strong-pw>@db:5432/sentry
DISPATCHER_DATABASE_URL=

# ----------------------------------------------------------------------
# Webhook-dispatcher tunables (v1.6.0 D1 #173)
# ----------------------------------------------------------------------
# Each variable's allowed range is enforced at dispatcher boot
# (api/services/webhook_dispatcher/env_validator.py). Out-of-range
# values refuse boot with a clear message naming the offender.
#
# DISPATCHER_ENABLED: kill switch. Set to "false" to stop dispatch
# traffic without removing the container; the heartbeat keeps the
# healthcheck green so docker-compose does not enter a restart loop.
# Anything other than the literal lowercase "false" is treated as
# enabled (deliberate: the kill switch should not silently engage).
DISPATCHER_ENABLED=true

# HTTP wall-clock cap per delivery POST. Range: 1000-60000 ms.
# #237: this is the total deadline the dispatcher enforces on a
# send via a thread watchdog; if the consumer drip-feeds bytes
# within the per-op read budget, the wall-clock cap fires first.
DISPATCHER_HTTP_TIMEOUT_MS=10000

# Per-operation timeouts. CONNECT bounds DNS + TCP + TLS handshake;
# READ bounds each socket read. Both must satisfy
# CONNECT + READ <= TIMEOUT (env_validator boot guard).
# Range: 100-60000 ms each.
DISPATCHER_HTTP_CONNECT_TIMEOUT_MS=5000
DISPATCHER_HTTP_READ_TIMEOUT_MS=8000

# Fallback poll interval when LISTEN/NOTIFY misses. Range: 500-10000 ms.
DISPATCHER_FALLBACK_POLL_MS=2000

# Drain window on SIGTERM before force-closing in-flight POSTs.
# Range: 1-300 s.
DISPATCHER_SHUTDOWN_DRAIN_S=30

# Concurrent HTTP POSTs across all subscriptions. Range: 1-100.
DISPATCHER_MAX_CONCURRENT_POSTS=16

# Deployment-wide hard caps that bound per-subscription override
# fields on webhook_subscriptions. The admin endpoint refuses any
# per-subscription value above these. Operator-only (env vars) so
# an admin who can pause cannot also raise the safety ceiling.
# Ranges: 1000-10_000_000 / 100-1_000_000.
DISPATCHER_MAX_PENDING_HARD_CAP=50000
DISPATCHER_MAX_DLQ_HARD_CAP=5000

# Dangerous opt-outs. Defaults (false) keep the v1.6.0 policy in
# effect: HTTPS-only delivery URLs in production AND dispatch-time
# DNS resolution that rejects RFC1918 / loopback / IMDS targets.
# The env_validator combination guard refuses to boot when both
# are true (SSRF-into-VPC) AND when SENTRY_ALLOW_INTERNAL_WEBHOOKS
# is true with FLASK_ENV=production.
#
# Use SENTRY_ALLOW_HTTP_WEBHOOKS only for dev/CI. Use
# SENTRY_ALLOW_INTERNAL_WEBHOOKS only when you need to dispatch
# to a private-range endpoint in dev/CI; the dispatcher logs
# CRITICAL on every boot so the acknowledgement stays visible.
SENTRY_ALLOW_HTTP_WEBHOOKS=false
SENTRY_ALLOW_INTERNAL_WEBHOOKS=false

# ----------------------------------------------------------------------
# v1.5.1 V-206 (#147) -- NEVER SET TRUST_PROXY=true AND API_BIND_HOST=0.0.0.0
# TOGETHER.
# ----------------------------------------------------------------------
# Setting both means (a) the api container trusts X-Forwarded-* from any
# caller, AND (b) the api container port is reachable on every host
# interface. An attacker who reaches port 5000 directly (cloud misconfig,
# Security Group error, bastion misroute) can then spoof X-Forwarded-For
# to poison every rate-limit bucket, audit-log user attribution, and any
# downstream IP-based allowlist. The api refuses to boot on this combo
# starting in v1.5.1. If the combination is intentional (network-level
# protection applied elsewhere, e.g. a cloud VPC lock-down), acknowledge
# the risk by setting SENTRY_ALLOW_OPEN_BIND=1. Use sparingly.
