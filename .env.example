# Database (change credentials for production)
POSTGRES_USER=sentry
POSTGRES_PASSWORD=sentry
POSTGRES_DB=sentry

# REQUIRED: Must match POSTGRES_USER/PASSWORD/DB above
# Docker Compose sets this automatically; only needed for standalone API
DATABASE_URL=postgresql://sentry:sentry@localhost:5432/sentry
FLASK_ENV=development
FLASK_PORT=5000

# REQUIRED: Generate with `openssl rand -hex 32`
JWT_SECRET=replace-me-with-openssl-rand-hex-32

# REQUIRED: Master key for connector credential vault (Fernet, base64, 32 bytes).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key requires decrypting all connector_credentials rows with the old
# key and re-encrypting with the new one; do not change in place.
SENTRY_ENCRYPTION_KEY=replace-me-with-fernet-generate-key

# REQUIRED: Password for the Redis broker (Celery uses Redis for task queuing).
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Rotating this requires restarting the Redis container and all Celery workers.
REDIS_PASSWORD=replace-me-with-secrets-token-hex-32

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080,http://localhost:8081

# Docker port bindings. Default 127.0.0.1 is correct for production deployments
# behind a reverse proxy. For LAN development where a mobile device needs to
# reach the API directly, set these to 0.0.0.0.
API_BIND_HOST=127.0.0.1
ADMIN_BIND_HOST=127.0.0.1
