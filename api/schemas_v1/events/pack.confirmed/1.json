{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentry-wms.example/events/pack.confirmed/1.json",
  "title": "pack.confirmed v1",
  "description": "A sales order has been packed. Emitted by api/routes/packing.py::complete_packing. Aggregate: sales_order. Sentry ships single-package today; packages[] carries a synthesized entry keyed {sales_order_external_id}-pkg-1. Multi-package support is v1.5.x+.",
  "type": "object",
  "required": [
    "sales_order_external_id",
    "packages",
    "completed_by_user_external_id",
    "completed_at"
  ],
  "additionalProperties": false,
  "properties": {
    "sales_order_external_id": { "type": "string", "format": "uuid" },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["package_external_id", "lines"],
        "additionalProperties": false,
        "properties": {
          "package_external_id": { "type": "string" },
          "weight_lb": { "type": ["number", "null"] },
          "dimensions_in": {
            "type": ["object", "null"],
            "description": "Not tracked in Sentry today; always null. See plan section 1.7.1 pack.confirmed notes."
          },
          "lines": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["item_external_id", "quantity_packed"],
              "additionalProperties": false,
              "properties": {
                "item_external_id": { "type": "string", "format": "uuid" },
                "quantity_packed": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "completed_by_user_external_id": { "type": "string", "format": "uuid" },
    "completed_at": { "type": "string", "format": "date-time" }
  }
}
