{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentry-wms.example/events/pick.confirmed/1.json",
  "title": "pick.confirmed v1",
  "description": "One sales order has flipped to PICKED inside a batch. Emitted by api/services/picking_service.py::complete_batch once per SO. Aggregate: sales_order.",
  "type": "object",
  "required": [
    "sales_order_external_id",
    "lines",
    "completed_by_user_external_id",
    "completed_at"
  ],
  "additionalProperties": false,
  "properties": {
    "sales_order_external_id": { "type": "string", "format": "uuid" },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item_external_id", "quantity_picked"],
        "additionalProperties": false,
        "properties": {
          "item_external_id": { "type": "string", "format": "uuid" },
          "quantity_picked": { "type": "integer", "minimum": 0 },
          "lot_number": { "type": ["string", "null"] },
          "serial_number": { "type": ["string", "null"] }
        }
      }
    },
    "completed_by_user_external_id": { "type": "string", "format": "uuid" },
    "completed_at": { "type": "string", "format": "date-time" }
  }
}
