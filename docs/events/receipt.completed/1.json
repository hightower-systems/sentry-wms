{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentry-wms.example/events/receipt.completed/1.json",
  "title": "receipt.completed v1",
  "description": "One PO receipt has been closed. Emitted by api/routes/receiving.py at the close path. Aggregate: item_receipts.",
  "type": "object",
  "required": [
    "receipt_external_id",
    "po_external_id",
    "lines",
    "completed_by_user_external_id",
    "completed_at"
  ],
  "additionalProperties": false,
  "properties": {
    "receipt_external_id": { "type": "string", "format": "uuid" },
    "po_external_id": { "type": "string", "format": "uuid" },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item_external_id", "quantity_received"],
        "additionalProperties": false,
        "properties": {
          "item_external_id": { "type": "string", "format": "uuid" },
          "quantity_received": { "type": "integer", "minimum": 0 },
          "lot_number": { "type": ["string", "null"] },
          "serial_number": { "type": ["string", "null"] }
        }
      }
    },
    "completed_by_user_external_id": { "type": "string", "format": "uuid" },
    "completed_at": { "type": "string", "format": "date-time" }
  }
}
