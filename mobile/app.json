{
  "expo": {
    "name": "Sentry WMS",
    "slug": "sentry-wms",
    "version": "0.9.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sentrywms.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.sentrywms.mobile"
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store"
    ]
  }
}
