{
  "name": "sentry-wms-mobile",
  "version": "1.3.0",
  "description": "Sentry WMS - Mobile Scanner App",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "npx eas-cli build --platform android --profile preview",
    "build:dev": "npx eas-cli build --platform android --profile development",
    "build:prod": "npx eas-cli build --platform android --profile production",
    "test": "vitest run"
  },
  "dependencies": {
    "@0no-co/graphql.web": "^1.2.0",
    "@expo/env": "^2.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "^54.0.0",
    "expo-asset": "~12.0.12",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "^55.0.17",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "babel-preset-expo": "^55.0.16",
    "eas-cli": "^18.5.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "tar": "^7.5.13"
  },
  "_overridesNote": "tar pinned to >=7.5.11 to fix GHSA-83g3-92jg-28cx, GHSA-qffp-2rhf-9h96, GHSA-9ppj-qmqm-q256 (path traversal) which surface in prod tree via expo -> @expo/cli -> tar.",
  "private": true
}
